#include <stdio.h>

#define MAX 10

void input(int a[MAX][MAX], int r, int c) {
    int i, j;
    for(i = 0; i < r; i++)
        for(j = 0; j < c; j++)
            scanf("%d", &a[i][j]);
}

void print(int a[MAX][MAX], int r, int c) {
    int i, j;
    for(i = 0; i < r; i++) {
        for(j = 0; j < c; j++)
            printf("%d ", a[i][j]);
        printf("\n");
    }
}

void add(int a[MAX][MAX], int b[MAX][MAX], int r, int c) {
    int i, j, sum[MAX][MAX];
    for(i = 0; i < r; i++)
        for(j = 0; j < c; j++)
            sum[i][j] = a[i][j] + b[i][j];

    printf("Result:\n");
    print(sum, r, c);
}

void saddle(int a[MAX][MAX], int r, int c) {
    int i, j, k, min, col, flag = 0;

    for(i = 0; i < r; i++) {
        min = a[i][0];
        col = 0;
        for(j = 1; j < c; j++) {
            if(a[i][j] < min) {
                min = a[i][j];
                col = j;
            }
        }
        for(k = 0; k < r; k++) {
            if(a[k][col] > min)
                break;
        }
        if(k == r) {
            printf("Saddle Point = %d\n", min);
            flag = 1;
        }
    }
    if(flag == 0)
        printf("No Saddle Point\n");
}

void inverse2x2(int a[2][2]) {
    int det = a[0][0]*a[1][1] - a[0][1]*a[1][0];

    if(det == 0) {
        printf("Inverse not possible\n");
        return;
    }

    printf("Inverse Matrix:\n");
    printf("%.2f %.2f\n", (float)a[1][1]/det, (float)-a[0][1]/det);
    printf("%.2f %.2f\n", (float)-a[1][0]/det, (float)a[0][0]/det);
}

void magic(int a[MAX][MAX], int n) {
    int i, j, sum = 0, diag1 = 0, diag2 = 0;

    for(j = 0; j < n; j++)
        sum += a[0][j];

    for(i = 0; i < n; i++) {
        int rowsum = 0, colsum = 0;
        for(j = 0; j < n; j++) {
            rowsum += a[i][j];
            colsum += a[j][i];
        }
        if(rowsum != sum || colsum != sum) {
            printf("Not a Magic Square\n");
            return;
        }
    }

    for(i = 0; i < n; i++) {
        diag1 += a[i][i];
        diag2 += a[i][n-i-1];
    }

    if(diag1 == sum && diag2 == sum)
        printf("Magic Square\n");
    else
        printf("Not a Magic Square\n");
}

int main() {
    int a[MAX][MAX], b[MAX][MAX];
    int r, c, choice, n;

    while(1) {
        printf("\n1.Addition\n2.Saddle Point\n3.Inverse (2x2)\n4.Magic Square\n5.Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch(choice) {
            case 1:
                printf("Enter rows and cols: ");
                scanf("%d%d", &r, &c);
                printf("Enter Matrix A:\n");
                input(a, r, c);
                printf("Enter Matrix B:\n");
                input(b, r, c);
                add(a, b, r, c);
                break;

            case 2:
                printf("Enter rows and cols: ");
                scanf("%d%d", &r, &c);
                printf("Enter Matrix:\n");
                input(a, r, c);
                saddle(a, r, c);
                break;

            case 3:
                printf("Enter 2x2 Matrix:\n");
                input(a, 2, 2);
                inverse2x2(a);
                break;

            case 4:
                printf("Enter order of square matrix: ");
                scanf("%d", &n);
                printf("Enter Matrix:\n");
                input(a, n, n);
                magic(a, n);
                break;

            case 5:
                return 0;

            default:
                printf("Invalid choice\n");
        }
    }
}
