#include <stdio.h>
#include <string.h>

struct employee
{
    char name[50];
    char desig[50];
    char gender;
    int day, month, year;
    float salary;
};

void total_emp(int n)
{
    printf("\nTotal employees = %d", n);
}

void count_gender(struct employee e[], int n)
{
    int i, m = 0, f = 0;

    for(i = 0; i < n; i++)
    {
        if(e[i].gender == 'M' || e[i].gender == 'm')
            m++;
        else if(e[i].gender == 'F' || e[i].gender == 'f')
            f++;
    }

    printf("\nMale = %d", m);
    printf("\nFemale = %d", f);
}

void salary_check(struct employee e[], int n)
{
    int i;
    printf("\nEmployees with salary > 10000:\n");

    for(i = 0; i < n; i++)
    {
        if(e[i].salary > 10000)
            printf("%s\n", e[i].name);
    }
}

void desig_check(struct employee e[], int n)
{
    int i;
    printf("\nEmployees with designation Asst Manager:\n");

    for(i = 0; i < n; i++)
    {
        if(strcmp(e[i].desig, "Asst Manager") == 0)
            printf("%s\n", e[i].name);
    }
}

int main()
{
    struct employee e[10];
    int n, i;

    printf("Enter number of employees: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
    {
        printf("\nEnter details of employee %d\n", i+1);

        printf("Name: ");
        scanf("%s", e[i].name);

        printf("Designation: ");
        scanf("%s", e[i].desig);

        printf("Gender (M/F): ");
        scanf(" %c", &e[i].gender);

        printf("Date of Joining (dd mm yyyy): ");
        scanf("%d %d %d", &e[i].day, &e[i].month, &e[i].year);

        printf("Salary: ");
        scanf("%f", &e[i].salary);
    }

    total_emp(n);
    count_gender(e, n);
    salary_check(e, n);
    desig_check(e, n);

    return 0;
}
