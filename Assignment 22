#include <stdio.h>
#include <string.h>

int main()
{
    char str1[100], str2[100];
    int ch;

    while(1)
    {
        printf("\n1.Length\n2.Copy\n3.Concatenate\n4.Compare\n5.Reverse\n6.Exit\n");
        printf("Enter choice: ");
        scanf("%d", &ch);

        switch(ch)
        {
            case 1:
                printf("Enter string: ");
                scanf("%s", str1);
                printf("Length = %lu", strlen(str1));
                break;

            case 2:
                printf("Enter string: ");
                scanf("%s", str1);
                strcpy(str2, str1);
                printf("Copied string = %s", str2);
                break;

            case 3:
                printf("Enter first string: ");
                scanf("%s", str1);
                printf("Enter second string: ");
                scanf("%s", str2);
                strcat(str1, str2);
                printf("Concatenated string = %s", str1);
                break;

            case 4:
                printf("Enter first string: ");
                scanf("%s", str1);
                printf("Enter second string: ");
                scanf("%s", str2);
                if(strcmp(str1, str2) == 0)
                    printf("Strings are equal");
                else
                    printf("Strings are not equal");
                break;

            case 5:
                printf("Enter string: ");
                scanf("%s", str1);
                strrev(str1);
                printf("Reversed string = %s", str1);
                break;

            case 6:
                return 0;

            default:
                printf("Invalid choice");
        }
    }
}
