#include <stdio.h>
#include <math.h>

int main()
{
    int n, i, flag = 1;
    long long fact = 1;

    printf("Enter a number: ");
    scanf("%d", &n);

    printf("\nSquare root = %.2f", sqrt(n));
    printf("\nSquare = %d", n * n);
    printf("\nCube = %d", n * n * n);

    if(n <= 1)
        flag = 0;
    else
    {
        for(i = 2; i <= n/2; i++)
        {
            if(n % i == 0)
            {
                flag = 0;
                break;
            }
        }
    }

    if(flag == 1)
        printf("\nPrime number");
    else
        printf("\nNot a prime number");

    if(n < 0)
        printf("\nFactorial not possible");
    else
    {
        for(i = 1; i <= n; i++)
            fact = fact * i;
        printf("\nFactorial = %lld", fact);
    }

    printf("\nPrime factors: ");
    for(i = 2; i <= n; i++)
    {
        while(n % i == 0)
        {
            printf("%d ", i);
            n = n / i;
        }
    }

    return 0;
}
