#include <stdio.h>
#include <math.h>

int main()
{
    int n, i, sign = 1;
    float x, sum = 0, term;
    long long fact;
    int power;

    printf("Enter value of x (in radians): ");
    scanf("%f", &x);

    printf("Enter number of terms: ");
    scanf("%d", &n);

    for(i = 1; i <= n; i++)
    {
        fact = 1;
        power = 2*i - 1;

        for(int j = 1; j <= power; j++)
            fact = fact * j;

        term = pow(x, power) / fact;

        sum = sum + sign * term;
        sign = -sign;
    }

    printf("Sum of sine series = %.4f", sum);

    return 0;
}
