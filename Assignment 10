#include <stdio.h>

long long fact(int n)
{
    long long f = 1;
    int i;
    for(i = 1; i <= n; i++)
        f = f * i;
    return f;
}

int main()
{
    int ch;
    float a, b, result;
    int n, i;
    long long power = 1;

    while(1)
    {
        printf("\n1.Addition\n2.Subtraction\n3.Multiplication\n4.Division\n5.Power(x^y)\n6.Factorial(x!)\n7.Exit\n");
        printf("Enter choice: ");
        scanf("%d", &ch);

        switch(ch)
        {
            case 1:
                printf("Enter two numbers: ");
                scanf("%f %f", &a, &b);
                printf("Result = %.2f", a + b);
                break;

            case 2:
                printf("Enter two numbers: ");
                scanf("%f %f", &a, &b);
                printf("Result = %.2f", a - b);
                break;

            case 3:
                printf("Enter two numbers: ");
                scanf("%f %f", &a, &b);
                printf("Result = %.2f", a * b);
                break;

            case 4:
                printf("Enter two numbers: ");
                scanf("%f %f", &a, &b);
                if(b == 0)
                    printf("Division not possible");
                else
                    printf("Result = %.2f", a / b);
                break;

            case 5:
                printf("Enter x and y: ");
                scanf("%f %f", &a, &b);
                power = 1;
                for(i = 1; i <= b; i++)
                    power = power * a;
                printf("Result = %lld", power);
                break;

            case 6:
                printf("Enter number: ");
                scanf("%d", &n);
                if(n < 0)
                    printf("Not possible");
                else
                    printf("Result = %lld", fact(n));
                break;

            case 7:
                return 0;

            default:
                printf("Invalid choice");
        }
    }
}
